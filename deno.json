{
  "workspace": [
    "./packages/cli",
    "./packages/server",
    "./packages/spa",
    "./packages/role-runtimes",
    "./packages/shared"
  ],
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/uuid": "jsr:@std/uuid@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "zod": "npm:zod@^4"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true
  },
  "fmt": {
    "include": ["packages/", "README.md"],
    "lineWidth": 100
  },
  "lint": {
    "include": ["packages/"]
  },
  "test": {
    "include": ["packages/"]
  },
  "tasks": {
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check packages",
    "test": "deno test -A",
    "build": "deno task --filter=@keni/* build"
  }
}
